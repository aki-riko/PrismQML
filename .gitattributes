# 自动生成文件标记
fluentqml/python/core/icons.py linguist-generated=true

# 统一行尾为 LF,防止跨平台/批量编辑导致 CRLF↔LF diff 噪声
*.qml text eol=lf
*.py  text eol=lf
*.js  text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.toml text eol=lf
qmldir text eol=lf

# 二进制资源(防止行尾规范化破坏 + GitHub 语言统计排除)
*.rcc binary
*.png binary
*.jpg binary
*.qsb binary
*.svg linguist-detectable=false
